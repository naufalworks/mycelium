# Mycelium — Root files to ignore
# This is a persistent brain, not code.
# Ignore runtime data — only track structure + tooling.

# SQLite index (auto-rebuilt, no reason to track)
index.db
index.db-shm
index.db-wal
log.jsonl
archive

# Branches (ephemeral exploration data)
branches/

# Evolution engine data (runtime, auto-generated)
evolution/failures.jsonl
evolution/patches.jsonl
evolution/patches.tmp
evolution/stats.db
evolution/stats.db-shm
evolution/stats.db-wal

# Garden state (auto-generated, session-specific)
garden/patterns.json
garden/state.json

# v3 LSM runtime data (auto-generated, rebuilt via migrate/compact)
l1/
l2/
objects/
snapshots/
.bloom_entities
.bloom_entities-journal
benchmark_results.json

# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# Local tooling / build artifacts
.hermes/
web/frontend/node_modules/
web/frontend/dist/
web/frontend/.vite/

# Editors
*.swp
*.swo
*~
.vscode/
.idea/

# Git
*.orig

# Go binaries
go/mycelium-proxy
go/mycelium-mcp
