{
  "productName": "Mycelium Stream",
  "version": "0.1.0",
  "identifier": "com.mycelium.stream",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "trunk serve",
    "beforeBuildCommand": "trunk build"
  },
  "app": {
    "windows": [{
      "title": "mycelium stream",
      "width": 1200,
      "height": 800,
      "resizable": true,
      "fullscreen": false
    }],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:8421; style-src 'self' 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": ["src-tauri/icons/32x32.png", "src-tauri/icons/128x128.png", "src-tauri/icons/icon.icns"]
  }
}
