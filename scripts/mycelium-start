#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd)"

# ── Pre-flight health gate (mandatory) ──
echo "🍄 Pre-flight check"
python3 "$ROOT/precheck.py"
PRECHECK_EXIT=$?
if [ $PRECHECK_EXIT -ne 0 ]; then
  echo "⚠️  Pre-flight failed — attempting fix"
  # re-run precheck which auto-fixes what it can
  python3 "$ROOT/precheck.py"
fi

echo
if [ -x "$ROOT/install-myceliumd.sh" ]; then
  echo "🍄 Ensuring myceliumd runtime"
  bash "$ROOT/install-myceliumd.sh" >/dev/null
else
  echo "🍄 install-myceliumd.sh missing — skipping runtime refresh"
fi

echo
echo "🍄 Resume"
python3 "$ROOT/mycelium.py" resume

echo
echo "🍄 Pattern scan"
python3 "$ROOT/detect-patterns.py"

echo
echo "🧬 Evolution patches"
python3 "$ROOT/evolution.py" load 2>/dev/null || echo "  (no active patches)"

echo
echo "🍄 Daemon state"
cat "$HOME/.hermes/myceliumd/state.json" 2>/dev/null || echo "state missing"
echo
