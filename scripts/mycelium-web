#!/usr/bin/env bash
set -euo pipefail

ROOT="$HOME/Documents/mycelium"
RUNTIME_DIR="$HOME/.hermes/myceliumd/web"
PID_DIR="$RUNTIME_DIR/pids"
LOG_DIR="$RUNTIME_DIR/logs"
LAUNCHD_DIR="$HOME/Library/LaunchAgents"
PLIST_NAME="com.naufalworks.mycelium-observatory.plist"
PLIST_PATH="$LAUNCHD_DIR/$PLIST_NAME"
BACKEND_PID="$PID_DIR/backend.pid"
FRONTEND_PID="$PID_DIR/frontend.pid"
BACKEND_LOG="$LOG_DIR/backend.log"
FRONTEND_LOG="$LOG_DIR/frontend.log"
SERVICE_LOG="$LOG_DIR/service.log"
BACKEND_URL="http://127.0.0.1:8421/api/health"
FRONTEND_URL="http://127.0.0.1:8421"
BACKEND_PORT=8421
FRONTEND_PORT=8420

mkdir -p "$PID_DIR" "$LOG_DIR" "$LAUNCHD_DIR"

say() {
  printf "%s\n" "$1"
}

banner() {
  say "mycelium observatory"
}

ritual_start() {
  say "→ spinning the observatory"
  say "→ binding the vault"
  say "→ opening the canopy"
}

ritual_ready() {
  say "→ mycelium web ready"
  say "→ app      $FRONTEND_URL"
  say "→ backend  $BACKEND_URL"
}

is_running() {
  local pid="$1"
  [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

read_pid() {
  local file="$1"
  [[ -f "$file" ]] || return 1
  tr -d '[:space:]' < "$file"
}

port_pid() {
  local port="$1"
  lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null | head -n 1 || true
}

wait_http() {
  local url="$1"
  python3 - "$url" <<'PY'
import sys, time, urllib.request
url = sys.argv[1]
for _ in range(80):
    try:
        with urllib.request.urlopen(url, timeout=1) as r:
            if 200 <= r.status < 500:
                raise SystemExit(0)
    except Exception:
        time.sleep(0.25)
raise SystemExit(1)
PY
}

start_backend() {
  local pid=""
  pid=$(port_pid "$BACKEND_PORT")
  if [[ -n "$pid" ]]; then
    echo "$pid" > "$BACKEND_PID"
    say "backend already awake → pid $pid"
    return 0
  fi
  if pid=$(read_pid "$BACKEND_PID" 2>/dev/null) && is_running "$pid"; then
    say "backend already awake → pid $pid"
    return 0
  fi
  cd "$ROOT"
  nohup env PYTHONPATH="$ROOT" python3 -m uvicorn web.backend.app:app --host 127.0.0.1 --port "$BACKEND_PORT" > "$BACKEND_LOG" 2>&1 &
  local spawned=$!
  echo "$spawned" > "$BACKEND_PID"
  if wait_http "$BACKEND_URL"; then
    pid=$(port_pid "$BACKEND_PORT")
    [[ -n "$pid" ]] && echo "$pid" > "$BACKEND_PID"
    say "backend up → pid ${pid:-$spawned}"
  else
    say "backend failed → see $BACKEND_LOG"
    return 1
  fi
}

stop_backend() {
  local pid=""
  pid=$(port_pid "$BACKEND_PORT")
  if [[ -n "$pid" ]]; then
    kill "$pid" 2>/dev/null || true
    sleep 0.5
    if is_running "$pid"; then
      kill -9 "$pid" 2>/dev/null || true
    fi
    say "backend asleep → pid $pid"
  else
    say "backend already asleep"
  fi
  rm -f "$BACKEND_PID"
}

status_one() {
  local name="$1"
  local file="$2"
  local url="$3"
  local port="$4"
  local pid=""
  pid=$(port_pid "$port")
  if [[ -n "$pid" ]]; then
    echo "$pid" > "$file"
    say "$name running → pid $pid · $url"
  else
    say "$name down"
  fi
}

open_ui() {
  say "→ opening observatory"
  open "$FRONTEND_URL"
}

logs_ui() {
  say "backend log → $BACKEND_LOG"
  tail -n 40 "$BACKEND_LOG" 2>/dev/null || true
  echo
  say "service log → $SERVICE_LOG"
  tail -n 40 "$SERVICE_LOG" 2>/dev/null || true
}

write_plist() {
  cat > "$PLIST_PATH" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.naufalworks.mycelium-observatory</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-lc</string>
    <string>cd "$ROOT" &amp;&amp; export PYTHONPATH="$ROOT" &amp;&amp; python3 -m uvicorn web.backend.app:app --host 127.0.0.1 --port $BACKEND_PORT</string>
  </array>
  <key>WorkingDirectory</key>
  <string>$ROOT</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>$SERVICE_LOG</string>
  <key>StandardErrorPath</key>
  <string>$SERVICE_LOG</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PYTHONPATH</key>
    <string>$ROOT</string>
  </dict>
</dict>
</plist>
PLIST
}

install_service() {
  write_plist
  launchctl unload "$PLIST_PATH" >/dev/null 2>&1 || true
  launchctl load "$PLIST_PATH"
  wait_http "$BACKEND_URL"
  say "launchd installed → $PLIST_PATH"
  say "service ready → $FRONTEND_URL"
}

uninstall_service() {
  launchctl unload "$PLIST_PATH" >/dev/null 2>&1 || true
  rm -f "$PLIST_PATH"
  say "launchd removed → $PLIST_PATH"
}

service_status() {
  if [[ -f "$PLIST_PATH" ]]; then
    say "launchd installed → $PLIST_PATH"
  else
    say "launchd not installed"
  fi
  status_one backend "$BACKEND_PID" "$BACKEND_URL" "$BACKEND_PORT"
}

case "${1:-start}" in
  start)
    banner
    ritual_start
    start_backend
    ritual_ready
    ;;
  stop)
    banner
    stop_backend
    ;;
  restart)
    banner
    "$0" stop
    "$0" start
    ;;
  status)
    banner
    status_one backend "$BACKEND_PID" "$BACKEND_URL" "$BACKEND_PORT"
    ;;
  open)
    banner
    open_ui
    ;;
  logs)
    banner
    logs_ui
    ;;
  install-service)
    banner
    install_service
    ;;
  uninstall-service)
    banner
    uninstall_service
    ;;
  service-status)
    banner
    service_status
    ;;
  *)
    echo "usage: $0 {start|stop|restart|status|open|logs|install-service|uninstall-service|service-status}"
    exit 1
    ;;
esac
